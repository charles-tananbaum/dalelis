---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Icon from "~/components/Icon.astro";
import TrustBar from "~/components/TrustBar.astro";
import BrandsMarquee from "~/components/BrandsMarquee.astro";
import CertificationsStrip from "~/components/CertificationsStrip.astro";
import { SITE } from "~/lib/site";

const values = [
  {
    title: "Show up on time.",
    body: "We tell you when we'll be there, and we're there. Your time is as valuable as ours.",
  },
  {
    title: "Plain language.",
    body: "No jargon, no upsell theater. We explain what's happening and what your options are in terms you can decide from.",
  },
  {
    title: "Fix it right.",
    body: "Root cause over quick patch. Long-term reliability over short-term profit. Every time.",
  },
  {
    title: "Stand behind the work.",
    body: "If you're not satisfied, we'll make it right. If we can't, we'll refund your money.",
  },
];

const milestones = [
  { year: 2009, label: "Dalelis Mechanical founded in Norwood" },
  { year: 2013, label: "Added full HVAC license and in-house HVAC team" },
  { year: 2018, label: "Expanded service area to 40+ MA communities" },
  { year: 2022, label: "Became a Mass Save residential partner" },
  { year: new Date().getFullYear(), label: `${SITE.yearsInBusiness}+ years, thousands of homes served` },
];
---

<BaseLayout
  title={`About ${SITE.name} | Norwood's Trusted Plumbing & HVAC Since ${SITE.foundedYear}`}
  description={`Locally owned and operated in Norwood, MA since ${SITE.foundedYear}. Licensed plumbing and HVAC specialists serving 40+ Massachusetts communities with honest workmanship.`}
>
  {/* Hero */}
  <section class="relative py-20 lg:py-32 overflow-hidden" style="background: var(--color-ivory);">
    <div class="container-page relative">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-end">
        <div class="lg:col-span-7" data-reveal>
          <span class="eyebrow">About us</span>
          <h1 class="mt-5 font-display text-5xl md:text-6xl lg:text-[6rem]" style="font-weight:400; letter-spacing:-0.035em; line-height:0.92;">
            Local.
            <span class="block" style="font-style:italic;">Licensed.</span>
            <span class="block">Honest.</span>
          </h1>
        </div>
        <div class="lg:col-span-5" data-reveal>
          <p class="text-lg lg:text-xl" style="color: var(--color-slate);">
            Dalelis Mechanical has been serving Norwood and greater Boston since {SITE.foundedYear}. What started as a one-truck plumbing shop is now a {SITE.yearsInBusiness}-year-old, dual-licensed plumbing and HVAC company — built on the same principles: show up when we say we will, explain what's going on in plain language, and fix the problem the right way.
          </p>
        </div>
      </div>
    </div>
  </section>

  <TrustBar />

  {/* Mission */}
  <section class="py-24 lg:py-36" style="background: var(--color-ivory);">
    <div class="container-page">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-4" data-reveal>
          <span class="eyebrow">Our promise</span>
          <h2 class="mt-4 font-display text-4xl lg:text-5xl" style="font-weight:450; letter-spacing:-0.025em; line-height:1;">
            What you can expect.
          </h2>
          <p class="mt-5 text-base lg:text-lg" style="color: var(--color-slate);">
            These aren't marketing slogans. They're the operating principles we actually work by, every day, on every call.
          </p>
        </div>
        <div class="lg:col-span-8">
          <div class="grid sm:grid-cols-2 gap-5 lg:gap-6">
            {values.map((v, i) => (
              <div class="p-8 lg:p-10 rounded-2xl"
                   style="background: var(--color-cream); border: 1px solid color-mix(in oklab, var(--color-ink) 8%, transparent);"
                   data-reveal>
                <div class="font-display text-3xl opacity-20 mb-3" style="font-weight:300;">0{i + 1}</div>
                <h3 class="font-display text-2xl lg:text-[1.65rem]" style="font-weight:500; letter-spacing:-0.015em;">{v.title}</h3>
                <p class="mt-3 text-base" style="color: var(--color-slate);">{v.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Timeline */}
  <section class="py-24 lg:py-36 overflow-hidden" style="background: var(--color-cream);">
    <div class="container-page">
      <div class="max-w-3xl mb-16" data-reveal>
        <span class="eyebrow">Our story</span>
        <h2 class="mt-4 font-display text-4xl lg:text-[4rem]" style="font-weight:400; letter-spacing:-0.03em; line-height:1;">
          {SITE.yearsInBusiness}+ years of
          <span style="font-style:italic;"> showing up.</span>
        </h2>
      </div>
      <div class="relative">
        {milestones.map((m, i) => (
          <div class="grid lg:grid-cols-12 gap-6 py-8 dashed-bottom" data-reveal>
            <div class="lg:col-span-3">
              <div class="font-display text-5xl lg:text-6xl" style="font-weight:300; color: var(--color-brass);">
                {m.year}
              </div>
            </div>
            <div class="lg:col-span-9 lg:pt-4">
              <p class="font-display text-xl lg:text-2xl" style="font-weight:450; letter-spacing:-0.015em;">{m.label}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Credentials */}
  <section class="py-24 lg:py-36" style="background: var(--color-ivory);">
    <div class="container-page">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div data-reveal>
          <span class="eyebrow">Credentials</span>
          <h2 class="mt-4 font-display text-4xl lg:text-5xl" style="font-weight:450; letter-spacing:-0.025em; line-height:1;">
            Fully licensed. Fully insured.
          </h2>
          <p class="mt-5 text-base lg:text-lg" style="color: var(--color-slate);">
            Dalelis Mechanical holds dual Massachusetts licenses for plumbing and HVAC. We carry full liability insurance and workers' compensation — so you and your home are protected on every job.
          </p>
          <dl class="mt-10 space-y-5">
            <div class="flex items-start gap-5 p-5 rounded-xl" style="background: var(--color-cream);">
              <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center" style="background: var(--color-ivory); color: var(--color-brass); border: 1px solid color-mix(in oklab, var(--color-ink) 8%, transparent);">
                <Icon name="award" size="1.15em" />
              </div>
              <div>
                <dt class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-slate);">Master Plumbing</dt>
                <dd class="font-display text-xl" style="font-weight:500;">MA License #{SITE.licenses.masterPlumbing}</dd>
              </div>
            </div>
            <div class="flex items-start gap-5 p-5 rounded-xl" style="background: var(--color-cream);">
              <div class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center" style="background: var(--color-ivory); color: var(--color-brass); border: 1px solid color-mix(in oklab, var(--color-ink) 8%, transparent);">
                <Icon name="shield" size="1.15em" />
              </div>
              <div>
                <dt class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-slate);">HVAC</dt>
                <dd class="font-display text-xl" style="font-weight:500;">MA License #{SITE.licenses.hvac}</dd>
              </div>
            </div>
          </dl>
        </div>
        <div data-reveal>
          <div class="relative aspect-square rounded-2xl overflow-hidden" style="box-shadow: var(--shadow-lift);">
            <img
              src="/images/stock/norwood.webp"
              alt="Downtown Norwood, Massachusetts at twilight"
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0" style="background: linear-gradient(180deg, transparent 55%, color-mix(in oklab, var(--color-ink) 50%, transparent) 100%);"></div>
            <div class="absolute bottom-5 left-5 right-5 flex items-center gap-2 px-3 py-2 rounded-full backdrop-blur-sm"
                 style="background: color-mix(in oklab, var(--color-ivory) 88%, transparent); color: var(--color-ink); width: fit-content;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span class="text-xs uppercase tracking-[0.14em] font-medium">Norwood, Massachusetts</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CertificationsStrip />
  <BrandsMarquee />
</BaseLayout>
