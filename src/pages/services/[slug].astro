---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Icon from "~/components/Icon.astro";
import RequestForm from "~/components/RequestForm.astro";
import TrustBar from "~/components/TrustBar.astro";
import { SITE } from "~/lib/site";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map((service) => ({
    params: { slug: service.id.replace(/\.md$/, '') },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);

// Find related services (same category, excluding self)
const all = await getCollection("services");
const related = all
  .filter((s) => s.data.category === service.data.category && s.id !== service.id)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: service.data.title,
  description: service.data.shortDescription,
  provider: { "@id": `${SITE.url}/#business` },
  areaServed: { "@type": "City", name: "Norwood", containedInPlace: { "@type": "State", name: "Massachusetts" } },
  serviceType: service.data.category,
};

const title = service.data.seoTitle ?? `${service.data.title} in Norwood, MA | ${SITE.name}`;
const description = service.data.seoDescription ?? service.data.shortDescription;

// Hero image map (stock, TODO: replace with real project photos)
const heroImages: Record<string, string> = {
  cooling: "/images/stock/hvac/residential-ac.jpg",
  heating: "/images/stock/hvac/crew-heat-pump.webp",
  plumbing: "/images/stock/plumbing/plumber-valves.jpg",
  hvac: "/images/stock/hvac/technician-rooftop.webp",
  "water-heaters": "/images/stock/plumbing/plumber-sink.jpg",
};
const heroImage = heroImages[service.data.category] ?? heroImages.hvac;
---

<BaseLayout title={title} description={description} schema={serviceSchema}>
  {/* Hero */}
  <section class="relative overflow-hidden" style="background: var(--color-ivory);">
    <div class="container-page pt-12 lg:pt-20 pb-20 lg:pb-32">
      <nav class="mb-10 flex items-center gap-2 text-sm" style="color: var(--color-slate);" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[var(--color-ink)]">Home</a>
        <Icon name="chevron-right" size="0.9em" />
        <a href="/services/" class="hover:text-[var(--color-ink)]">Services</a>
        <Icon name="chevron-right" size="0.9em" />
        <span style="color: var(--color-ink);">{service.data.title}</span>
      </nav>

      <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
        <div class="lg:col-span-7" data-reveal>
          {service.data.emergency && (
            <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs uppercase tracking-widest mb-5"
                  style="background: color-mix(in oklab, var(--color-brick) 10%, transparent); color: var(--color-brick); font-weight:600;">
              <Icon name="alert" size="0.9em" /> 24/7 Emergency
            </span>
          )}
          <span class="eyebrow">{service.data.category.replace('-', ' ')}</span>
          <h1 class="mt-4 font-display text-5xl md:text-6xl lg:text-[5.5rem]" style="font-weight:400; letter-spacing:-0.035em; line-height:0.95;">
            {service.data.title}
          </h1>
          <p class="mt-6 font-display text-2xl lg:text-3xl" style="font-weight:300; font-style: italic; color: var(--color-slate); line-height:1.2;">
            {service.data.heroTagline}
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href={SITE.phoneTel} class="btn btn-primary">
              <Icon name="phone" size="1em" />
              {SITE.phone}
            </a>
            <a href={SITE.booking} target="_blank" rel="noopener noreferrer" class="btn btn-accent">
              <Icon name="calendar" size="1em" />
              Book Online
            </a>
          </div>
        </div>

        <div class="lg:col-span-5" data-reveal>
          <div class="relative aspect-[4/5] rounded-2xl overflow-hidden"
               style="background: var(--color-cream); box-shadow: var(--shadow-lift);">
            <img src={heroImage} alt="" class="w-full h-full object-cover" loading="eager" />
            {/* TODO: replace with real Dalelis job photo */}
            <div class="absolute inset-0" style="background: linear-gradient(180deg, transparent 40%, color-mix(in oklab, var(--color-ink) 55%, transparent) 100%);"></div>
            <div class="absolute bottom-6 left-6 right-6 flex items-center gap-3">
              <div class="flex items-center gap-0.5" style="color: var(--color-brass);">
                {[...Array(5)].map(() => <Icon name="star" size="0.95em" />)}
              </div>
              <div class="text-sm" style="color: var(--color-ivory);">
                <strong>4.9</strong> on Google — since {SITE.foundedYear}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Overview body + side form */}
  <section class="py-20 lg:py-28" style="background: var(--color-cream);">
    <div class="container-page grid lg:grid-cols-12 gap-12 lg:gap-16">
      <article class="lg:col-span-7 prose-article">
        <div class="max-w-prose">
          <span class="eyebrow">Overview</span>
          <h2 class="mt-4 font-display text-3xl lg:text-[2.5rem]" style="font-weight:450; letter-spacing:-0.025em; line-height:1.1;">
            {service.data.shortDescription}
          </h2>
          <div class="mt-6 text-base lg:text-lg leading-relaxed" style="color: var(--color-slate);">
            <Content />
          </div>
        </div>

        {service.data.signsYouNeed && service.data.signsYouNeed.length > 0 && (
          <div class="mt-14 pt-14 dashed-top" data-reveal>
            <span class="eyebrow">Signs you may need this</span>
            <h3 class="mt-3 font-display text-3xl lg:text-4xl" style="font-weight:450; letter-spacing:-0.02em;">
              Call us if…
            </h3>
            <ul class="mt-8 grid sm:grid-cols-2 gap-x-8 gap-y-4">
              {service.data.signsYouNeed.map((sign) => (
                <li class="flex items-start gap-3">
                  <div class="flex-shrink-0 mt-1 w-5 h-5 rounded-full flex items-center justify-center"
                       style="background: color-mix(in oklab, var(--color-brass) 15%, transparent); color: var(--color-brass);">
                    <Icon name="check" size="0.75em" strokeWidth={3} />
                  </div>
                  <span class="text-base" style="color: var(--color-ink);">{sign}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {service.data.whatWeDo && service.data.whatWeDo.length > 0 && (
          <div class="mt-14 pt-14 dashed-top" data-reveal>
            <span class="eyebrow">What we do</span>
            <h3 class="mt-3 font-display text-3xl lg:text-4xl" style="font-weight:450; letter-spacing:-0.02em;">
              Our approach.
            </h3>
            <ul class="mt-8 space-y-0">
              {service.data.whatWeDo.map((item, i) => (
                <li class="flex items-start gap-6 py-5 dashed-bottom">
                  <div class="font-display text-sm pt-1.5" style="color: var(--color-brass); font-weight:500;">
                    {String(i + 1).padStart(2, '0')}
                  </div>
                  <div class="text-base lg:text-[1.05rem] flex-1" style="color: var(--color-ink);">{item}</div>
                </li>
              ))}
            </ul>
          </div>
        )}
      </article>

      <aside class="lg:col-span-5">
        <div class="lg:sticky lg:top-28 space-y-6">
          <RequestForm heading={`Request ${service.data.title}`} subheading="We'll call to confirm within the hour." />
          <div class="rounded-2xl p-6"
               style="background: var(--color-ink); color: var(--color-ivory);">
            <div class="flex items-center gap-2 text-xs uppercase tracking-widest mb-3" style="color: var(--color-brass);">
              <Icon name="clock" size="0.9em" /> 24/7 Emergency
            </div>
            <div class="font-display text-2xl" style="font-weight:450;">Need service now?</div>
            <p class="mt-2 text-sm" style="color: color-mix(in oklab, var(--color-ivory) 70%, transparent);">
              Real humans answer our phone around the clock. No call center, no answering service.
            </p>
            <a href={SITE.phoneTel} class="btn btn-accent w-full mt-4">
              <Icon name="phone" size="1em" />
              Call {SITE.phone}
            </a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  {/* Related */}
  {related.length > 0 && (
    <section class="py-20 lg:py-28" style="background: var(--color-ivory);">
      <div class="container-page">
        <div class="flex items-end justify-between gap-6 mb-10">
          <div data-reveal>
            <span class="eyebrow">Related services</span>
            <h2 class="mt-3 font-display text-3xl lg:text-5xl" style="font-weight:450; letter-spacing:-0.025em;">
              You might also need.
            </h2>
          </div>
          <a href="/services/" class="btn btn-ghost hidden md:inline-flex">
            All services <Icon name="arrow-right" size="1em" />
          </a>
        </div>
        <div class="grid md:grid-cols-3 gap-5">
          {related.map((r) => (
            <a href={`/services/${r.id.replace(/\.md$/, '')}/`}
               class="group block p-7 rounded-2xl transition-all hover:-translate-y-1"
               style="background: var(--color-cream); border: 1px solid color-mix(in oklab, var(--color-ink) 8%, transparent);">
              <h3 class="font-display text-xl lg:text-[1.4rem]" style="font-weight:500;">{r.data.title}</h3>
              <p class="mt-2 text-sm" style="color: var(--color-slate);">{r.data.shortDescription}</p>
              <div class="mt-5 flex items-center gap-2 text-sm font-medium transition-transform group-hover:translate-x-1" style="color: var(--color-brass);">
                Learn more <Icon name="arrow-right" size="1em" />
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .prose-article :global(h2),
  .prose-article :global(h3) {
    margin-top: 1.5em;
  }
  .prose-article :global(p) {
    margin-top: 1em;
  }
</style>
