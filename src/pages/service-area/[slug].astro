---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Icon from "~/components/Icon.astro";
import RequestForm from "~/components/RequestForm.astro";
import TrustBar from "~/components/TrustBar.astro";
import { SITE } from "~/lib/site";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const areas = await getCollection("serviceAreas");
  return areas.map((area) => ({
    params: { slug: area.id.replace(/\.md$/, '') },
    props: { area },
  }));
}

const { area } = Astro.props;

const services = [
  { title: "Emergency HVAC", slug: "emergency-hvac", icon: "alert" },
  { title: "AC Repair", slug: "ac-repair", icon: "snowflake" },
  { title: "Heating Repair", slug: "heating-repair", icon: "flame" },
  { title: "Furnace Install", slug: "furnace-installation", icon: "install" },
  { title: "Water Heater Install", slug: "water-heater-installation", icon: "droplet" },
  { title: "Plumbing Fixtures", slug: "fixture-installation", icon: "wrench" },
];

const title = `Plumbing & HVAC in ${area.data.name}, MA | ${SITE.name}`;
const description = `Licensed plumbing, heating, and air conditioning service in ${area.data.name}, MA. 24/7 emergency, 4.9★ Google rating. Call ${SITE.phone}.`;
---

<BaseLayout title={title} description={description}>
  <section class="relative py-20 lg:py-32 overflow-hidden" style="background: var(--color-ivory);">
    <div class="container-page">
      <nav class="mb-8 flex items-center gap-2 text-sm" style="color: var(--color-slate);" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[var(--color-ink)]">Home</a>
        <Icon name="chevron-right" size="0.9em" />
        <a href="/service-area/" class="hover:text-[var(--color-ink)]">Service Area</a>
        <Icon name="chevron-right" size="0.9em" />
        <span style="color: var(--color-ink);">{area.data.name}</span>
      </nav>

      <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
        <div class="lg:col-span-7" data-reveal>
          <span class="eyebrow"><Icon name="map-pin" size="0.9em" /> {area.data.name}, Massachusetts</span>
          <h1 class="mt-5 font-display text-5xl md:text-6xl lg:text-[5.75rem]" style="font-weight:400; letter-spacing:-0.035em; line-height:0.95;">
            Trusted plumbing & HVAC
            <span class="block" style="font-style:italic;">in {area.data.name}.</span>
          </h1>
          <p class="mt-8 text-lg lg:text-xl max-w-xl" style="color: var(--color-slate);">
            {area.data.intro}
          </p>
          <div class="mt-10 flex flex-wrap gap-3">
            <a href={SITE.phoneTel} class="btn btn-primary">
              <Icon name="phone" size="1em" /> {SITE.phone}
            </a>
            <a href={SITE.booking} target="_blank" rel="noopener noreferrer" class="btn btn-accent">
              <Icon name="calendar" size="1em" /> Book Online
            </a>
          </div>
        </div>

        <div class="lg:col-span-5" data-reveal>
          <RequestForm variant="card" heading={`Request service in ${area.data.name}`} subheading="We'll call to confirm within the hour." />
        </div>
      </div>
    </div>
  </section>

  <TrustBar />

  {/* Services offered in this area */}
  <section class="py-24 lg:py-32" style="background: var(--color-ivory);">
    <div class="container-page">
      <div class="mb-14 max-w-2xl" data-reveal>
        <span class="eyebrow">Services in {area.data.name}</span>
        <h2 class="mt-4 font-display text-4xl lg:text-5xl" style="font-weight:450; letter-spacing:-0.025em; line-height:1;">
          What we do for {area.data.name} homeowners.
        </h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
        {services.map((s) => (
          <a href={`/services/${s.slug}/`}
             class="group block p-7 rounded-2xl transition-all hover:-translate-y-1"
             style="background: var(--color-cream); border: 1px solid color-mix(in oklab, var(--color-ink) 8%, transparent);">
            <div class="w-12 h-12 rounded-full flex items-center justify-center mb-5"
                 style="background: var(--color-ivory); color: var(--color-brass); border: 1px solid color-mix(in oklab, var(--color-ink) 8%, transparent);">
              <Icon name={s.icon} size="1.15em" />
            </div>
            <h3 class="font-display text-xl lg:text-[1.4rem]" style="font-weight:500;">{s.title}</h3>
            <div class="mt-4 flex items-center gap-2 text-sm transition-transform group-hover:translate-x-1" style="color: var(--color-brass);">
              Learn more <Icon name="arrow-right" size="1em" />
            </div>
          </a>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href="/services/" class="btn btn-ghost">
          See all services <Icon name="arrow-right" size="1em" />
        </a>
      </div>
    </div>
  </section>

  {/* Local trust */}
  <section class="py-24 lg:py-32" style="background: var(--color-cream);">
    <div class="container-page max-w-4xl text-center">
      <span class="eyebrow">Why {area.data.name}?</span>
      <h2 class="mt-4 font-display text-4xl lg:text-[3.5rem]" style="font-weight:450; letter-spacing:-0.025em; line-height:1;">
        Local dispatch, local accountability.
      </h2>
      <p class="mt-6 text-lg lg:text-xl" style="color: var(--color-slate);">
        We're not a franchise or a national call center. When you call us, you reach a local Norwood-based team. When we show up, it's one of our licensed technicians — the same ones your neighbors already trust.
      </p>
      <div class="mt-10 inline-flex flex-wrap justify-center gap-3">
        <a href={SITE.phoneTel} class="btn btn-primary"><Icon name="phone" size="1em" /> {SITE.phone}</a>
        <a href={SITE.booking} target="_blank" rel="noopener noreferrer" class="btn btn-accent"><Icon name="calendar" size="1em" /> Book Online</a>
      </div>
    </div>
  </section>
</BaseLayout>
