---
import { SITE } from "~/lib/site";
import Icon from "./Icon.astro";

const nav = [
  { label: "Services", href: "/services/" },
  { label: "Service Area", href: "/service-area/" },
  { label: "Maintenance Plans", href: "/maintenance-plans/" },
  { label: "Reviews", href: "/reviews/" },
  { label: "About", href: "/about/" },
  { label: "Contact", href: "/contact/" },
];
---

<header
  class="sticky top-0 z-50 backdrop-blur-md"
  style="background: color-mix(in oklab, var(--color-ivory) 88%, transparent); border-bottom: 1px solid color-mix(in oklab, var(--color-ink) 8%, transparent);"
  data-header
>
  <div class="container-page">
    <div class="flex items-center justify-between h-16 lg:h-20">
      {/* Logo */}
      <a href="/" class="flex items-center gap-3 group" aria-label={`${SITE.name} — Home`}>
        <img
          src="/images/logo.jpg"
          alt=""
          width="56"
          height="56"
          class="w-11 h-11 lg:w-14 lg:h-14 object-contain"
          style="mix-blend-mode: multiply;"
          loading="eager"
        />
        <div class="flex flex-col leading-none">
          <span class="font-display text-base lg:text-[1.2rem] tracking-tight" style="font-weight:500;">Dalelis Mechanical</span>
          <span class="text-[0.6rem] lg:text-[0.65rem] uppercase tracking-[0.14em] mt-1" style="color: var(--color-slate);">Plumbing · Heating · Cooling · Est. 2009</span>
        </div>
      </a>

      {/* Desktop nav */}
      <nav class="hidden lg:flex items-center gap-8" aria-label="Primary">
        {nav.map((item) => (
          <a href={item.href}
             class="text-sm font-medium transition-colors hover:text-[var(--color-brass)]"
             style="color: var(--color-ink);">
            {item.label}
          </a>
        ))}
      </nav>

      {/* Desktop CTAs */}
      <div class="hidden lg:flex items-center gap-3">
        <a href={SITE.phoneTel}
           class="flex items-center gap-2 text-sm font-medium"
           style="color: var(--color-ink);">
          <Icon name="phone" size="1.05em" />
          <span>{SITE.phone}</span>
        </a>
        <a href={SITE.booking}
           target="_blank"
           rel="noopener noreferrer"
           class="btn btn-accent text-sm">
          <Icon name="calendar" size="1em" />
          Book Online
        </a>
      </div>

      {/* Mobile: phone icon + menu */}
      <div class="flex lg:hidden items-center gap-2">
        <a href={SITE.phoneTel}
           aria-label="Call Dalelis Mechanical"
           class="p-2.5 rounded-full"
           style="background: var(--color-ink); color: var(--color-ivory);">
          <Icon name="phone" size="1.1em" />
        </a>
        <button
          aria-label="Open menu"
          class="p-2.5 rounded-full"
          style="border: 1px solid color-mix(in oklab, var(--color-ink) 18%, transparent); color: var(--color-ink);"
          data-menu-toggle
        >
          <Icon name="menu" size="1.1em" />
        </button>
      </div>
    </div>
  </div>
</header>

{/*
  Mobile menu panel — MUST be a sibling of <header>, not a child.
  Reason: the header uses `backdrop-blur-md` which sets `backdrop-filter`, and
  per CSS spec that creates a new containing block for any `position: fixed`
  descendants. If this panel were inside <header> it would be constrained to
  the 64px-tall header bar instead of filling the viewport.
*/}
<div
  class="lg:hidden hidden fixed inset-0 z-[60]"
  data-mobile-menu
  aria-hidden="true"
>
  <div class="absolute inset-0" style="background: color-mix(in oklab, var(--color-ink) 70%, transparent);" data-menu-backdrop></div>
  <div class="absolute right-0 top-0 bottom-0 w-[88%] max-w-sm overflow-y-auto"
       style="background: var(--color-ivory); box-shadow: -20px 0 60px -20px rgba(12,26,46,0.3);">
    <div class="flex items-center justify-between p-5 dashed-bottom">
      <span class="font-display text-xl" style="font-weight:500;">Menu</span>
      <button aria-label="Close menu" class="p-2" data-menu-close>
        <Icon name="close" size="1.3em" />
      </button>
    </div>
    <nav class="p-5 flex flex-col gap-1" aria-label="Mobile">
      {nav.map((item) => (
        <a href={item.href}
           class="flex items-center justify-between py-4 px-2 dashed-bottom text-[1.05rem]"
           style="color: var(--color-ink);">
          <span class="font-display" style="font-weight:500;">{item.label}</span>
          <Icon name="chevron-right" size="1.1em" />
        </a>
      ))}
    </nav>
    <div class="p-5 space-y-3">
      <a href={SITE.booking} target="_blank" rel="noopener noreferrer" class="btn btn-accent w-full">
        <Icon name="calendar" size="1em" />
        Book Online
      </a>
      <a href={SITE.phoneTel} class="btn btn-primary w-full">
        <Icon name="phone" size="1em" />
        {SITE.phone}
      </a>
    </div>
  </div>
</div>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const panel = document.querySelector<HTMLDivElement>("[data-mobile-menu]");
  const backdrop = document.querySelector<HTMLDivElement>("[data-menu-backdrop]");
  const closeBtn = document.querySelector<HTMLButtonElement>("[data-menu-close]");

  const open = () => {
    panel?.classList.remove("hidden");
    panel?.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  };
  const close = () => {
    panel?.classList.add("hidden");
    panel?.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  };

  toggle?.addEventListener("click", open);
  backdrop?.addEventListener("click", close);
  closeBtn?.addEventListener("click", close);

  // Header shadow on scroll
  const header = document.querySelector<HTMLElement>("[data-header]");
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 8) {
      header.style.boxShadow = "0 8px 32px -16px rgba(12, 26, 46, 0.15)";
    } else {
      header.style.boxShadow = "none";
    }
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
