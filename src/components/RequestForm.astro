---
import { SITE } from "~/lib/site";
import Icon from "./Icon.astro";

interface Props {
  variant?: "inline" | "card";
  heading?: string;
  subheading?: string;
}
const {
  variant = "card",
  heading = "Request Service",
  subheading = "Tell us what you need. We'll call to confirm within the hour."
} = Astro.props;
---

<div class={variant === "card" ? "relative" : ""}>
  <div class={variant === "card"
    ? "relative rounded-2xl p-8 lg:p-10"
    : ""}
    style={variant === "card" ? "background: var(--color-cream); border: 1px solid color-mix(in oklab, var(--color-ink) 8%, transparent); box-shadow: var(--shadow-soft);" : ""}>
    {variant === "card" && (
      <>
        <span class="eyebrow">Fast response</span>
        <h3 class="font-display text-3xl lg:text-4xl mt-3" style="font-weight:450;">{heading}</h3>
        <p class="mt-3 text-sm lg:text-base" style="color: var(--color-slate);">{subheading}</p>
      </>
    )}

    <form class="mt-6 space-y-4" data-request-form action={SITE.emailMailto} method="post">
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="label" for="name">Your name</label>
          <input id="name" name="name" type="text" required class="input" placeholder="Jane Smith" />
        </div>
        <div>
          <label class="label" for="phone">Phone</label>
          <input id="phone" name="phone" type="tel" required class="input" placeholder="(617) 555-0100" />
        </div>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="label" for="service">Service needed</label>
          <select id="service" name="service" class="input" required>
            <option value="">Select a service</option>
            <option>Emergency — no heat / no AC</option>
            <option>AC repair</option>
            <option>AC installation</option>
            <option>Heating repair</option>
            <option>Furnace / boiler install</option>
            <option>Water heater</option>
            <option>Plumbing — fixture</option>
            <option>Plumbing — leak</option>
            <option>Maintenance / tune-up</option>
            <option>Other</option>
          </select>
        </div>
        <div>
          <label class="label" for="zip">ZIP code</label>
          <input id="zip" name="zip" type="text" inputmode="numeric" pattern="[0-9]{5}" maxlength="5" required class="input" placeholder="02062" />
        </div>
      </div>
      <div>
        <label class="label" for="message">Message (optional)</label>
        <textarea id="message" name="message" rows="3" class="input" placeholder="Tell us a bit about the problem…"></textarea>
      </div>
      <button type="submit" class="btn btn-accent w-full sm:w-auto mt-2">
        Request Service
        <Icon name="arrow-right" size="1em" />
      </button>
      <p class="text-xs mt-3" style="color: var(--color-slate);">
        Prefer to call? <a href={SITE.phoneTel} class="underline" style="color: var(--color-ink);">{SITE.phone}</a> · 24/7 emergency service.
      </p>
    </form>
  </div>
</div>

<script>
  // Progressive enhancement: open mail client with prefilled body
  const form = document.querySelector<HTMLFormElement>("[data-request-form]");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name = data.get("name");
    const phone = data.get("phone");
    const service = data.get("service");
    const zip = data.get("zip");
    const message = data.get("message") || "";
    const subject = encodeURIComponent(`Service Request — ${service}`);
    const body = encodeURIComponent(
      `Name: ${name}\nPhone: ${phone}\nZIP: ${zip}\nService: ${service}\n\n${message}`
    );
    window.location.href = `mailto:dalelismechanical@gmail.com?subject=${subject}&body=${body}`;
  });
</script>
